# ==============================================================================
# MIRZA LIVE SERVER v1 - ENVIRONMENT CONFIGURATION EXAMPLE
# ==============================================================================
# Copy this file to '.env' and fill in your actual sensitive credentials.
# NEVER commit your '.env' file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# YOUTUBE STREAM KEYS (Multi-Channel Support)
# ------------------------------------------------------------------------------
# Get your stream keys from YouTube Studio -> Go Live -> Stream Key (paste here)
YOUTUBE_STREAM_KEY_MAIN=xxxx-xxxx-xxxx-xxxx-xxxx
YOUTUBE_STREAM_KEY_LOFI=yyyy-yyyy-yyyy-yyyy-yyyy

# ------------------------------------------------------------------------------
# SERVER & ENGINE SETTINGS
# ------------------------------------------------------------------------------
# Default RTMP ingestion URL (YouTube Live 2)
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2

# System-wide log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
MIRZA_LOG_LEVEL=INFO

# Optional override for the FFmpeg binary path (e.g., C:/ffmpeg/bin/ffmpeg.exe)
# Leave blank or commented out if 'ffmpeg' is installed and in your system PATH.
# MIRZA_FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe

# ------------------------------------------------------------------------------
# RESOURCE & HEALTH MONITORING THRESHOLDS
# ------------------------------------------------------------------------------
# Alert if CPU utilization exceeds this percentage
MIRZA_MAX_CPU_PERCENT=85.0

# Alert if system RAM utilization exceeds this percentage
MIRZA_MAX_RAM_PERCENT=90.0
